{
  "openapi": "3.0.3",
  "info": {
    "title": "stream-example",
    "version": "1.0.0"
  },
  "paths": {
    "/stream/download": {
      "get": {
        "operationId": "streamDownload",
        "summary": "Stream download (octet-stream)",
        "responses": {
          "200": {
            "description": "Binary body; client reads via ReadCloser",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          }
        }
      }
    },
    "/stream/upload": {
      "post": {
        "operationId": "streamUpload",
        "summary": "Stream upload (octet-stream body as ReadCloser)",
        "requestBody": {
          "required": true,
          "content": {
            "application/octet-stream": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Accepted"
          }
        }
      }
    },
    "/stream/bidir": {
      "post": {
        "operationId": "streamBidir",
        "summary": "Upload + download (echo request stream in response)",
        "requestBody": {
          "required": true,
          "content": {
            "application/octet-stream": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Echo body as octet-stream",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          }
        }
      }
    }
  }
}
