{
  "openapi": "3.0.3",
  "info": {
    "title": "stream-bidir",
    "version": "1.0.0"
  },
  "paths": {
    "/stream/bidir": {
      "post": {
        "operationId": "streamBidir",
        "summary": "Upload + download (echo request stream in response)",
